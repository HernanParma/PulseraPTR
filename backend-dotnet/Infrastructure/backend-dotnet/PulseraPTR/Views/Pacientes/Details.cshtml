@model PacienteDetalleDto
@{
    ViewData["Title"] = $"Paciente - {Model.Nombre}";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-0">@Model.Nombre</h1>
        <p class="text-muted mb-0">Historial completo y eventos asociados</p>
    </div>
    <div class="text-end">
        <div class="mb-2">
            @if (Model.EstadoActual is null)
            {
                <span class="badge bg-secondary">Sin mediciones</span>
            }
            else
            {
                <span class="badge badge-estado-@Model.EstadoActual fs-6">Estado: @Model.EstadoActual</span>
            }
        </div>
        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Editar</a>
        <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Volver al listado</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3"><strong>Edad:</strong> @Model.Edad</div>
    <div class="col-md-3"><strong>DNI:</strong> @(Model.Dni ?? "-")</div>
    <div class="col-md-3"><strong>Activo:</strong> @(Model.Activo ? "Sí" : "No")</div>
    <div class="col-md-3"><strong>Última medición:</strong> @(Model.UltimaMedicionFechaHora?.ToString("g") ?? "-")</div>
    <div class="col-12"><strong>Contacto emergencia:</strong> @Model.ContactoEmergencia</div>
    <div class="col-12"><strong>Observaciones:</strong> @(Model.Observaciones ?? "-")</div>
</div>

@if (Model.Glucemia is not null)
{
    <div class="card shadow-sm mb-4 border-warning">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Panorama de glucemia</span>
            <a class="btn btn-sm btn-outline-warning" asp-controller="Glucose" asp-action="Dashboard" asp-route-id="@Model.Id">Ver dashboard completo</a>
        </div>
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <div class="text-muted small">Última glucemia</div>
                    <div class="fw-semibold">@(Model.Glucemia.LastReading is null ? "—" : $"{Model.Glucemia.LastReading.GlucoseMgDl} mg/dL")</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small">Promedio</div>
                    <div class="fw-semibold">@(Model.Glucemia.AverageMgDl?.ToString("0") ?? "—") mg/dL</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small">Mín / Máx</div>
                    <div class="fw-semibold">@(Model.Glucemia.MinMgDl?.ToString() ?? "—") / @(Model.Glucemia.MaxMgDl?.ToString() ?? "—")</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small">Hipo / Hiper</div>
                    <div class="fw-semibold">@Model.Glucemia.HypoglycemiaCount / @Model.Glucemia.HyperglycemiaCount</div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Fecha (UTC)</th>
                            <th>Valor</th>
                            <th>Rango</th>
                            <th>Etiqueta</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.Glucemia.RecentReadings.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-muted">Sin lecturas de glucemia todavía.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var r in Model.Glucemia.RecentReadings.Take(8))
                        {
                            var bandText = r.Band switch
                            {
                                GlucoseRangeBand.SevereHypoglycemia => "Hipoglucemia Severa",
                                GlucoseRangeBand.Hypoglycemia => "Hipoglucemia",
                                GlucoseRangeBand.Normal => "Normal",
                                GlucoseRangeBand.Hyperglycemia => "Hiperglucemia",
                                GlucoseRangeBand.SevereHyperglycemia => "Hiperglucemia Severa",
                                GlucoseRangeBand.CriticalIsolated => "Crítico",
                                _ => r.Band.ToString()
                            };
                            <tr>
                                <td class="text-nowrap">@r.ReadingDateTimeUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="fw-semibold">@r.GlucoseMgDl mg/dL</td>
                                <td>@bandText</td>
                                <td>@(string.IsNullOrWhiteSpace(r.Label) ? "—" : r.Label)</td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white fw-semibold">Historial de mediciones (@Model.Mediciones.Count)</div>
    <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Fecha</th>
                    <th>FC</th>
                    <th>Estado</th>
                    <th>Fuera de rango</th>
                    <th>Origen</th>
                    <th>Mensaje</th>
                    <th class="text-end" style="width:1%"></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var m in Model.Mediciones)
            {
                <tr>
                    <td class="text-nowrap">@m.FechaHora.ToString("g")</td>
                    <td>@m.FrecuenciaCardiaca</td>
                    <td><span class="badge badge-estado-@m.Estado">@m.Estado</span></td>
                    <td>@(m.EsFueraDeRango ? "Sí" : "No")</td>
                    <td>@m.OrigenDato</td>
                    <td>@(m.MensajeAlerta ?? "-")</td>
                    <td class="text-end">
                        <form asp-controller="Mediciones" asp-action="Delete" asp-route-id="@m.Id" method="post" class="d-inline"
                              onsubmit="return confirm('¿Eliminar esta medición de forma permanente?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnPacienteDetalleId" value="@Model.Id" />
                            <button type="submit" class="btn btn-sm btn-link btn-icon-borrar p-0 border-0" title="Eliminar medición" aria-label="Eliminar medición">
                                <i class="bi bi-trash fs-5"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">Alertas (@Model.Alertas.Count)</div>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Fecha</th>
                            <th>Tipo</th>
                            <th>Estado</th>
                            <th>Leída</th>
                            <th>Mensaje</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var a in Model.Alertas)
                    {
                        <tr>
                            <td class="text-nowrap">@a.FechaHora.ToString("g")</td>
                            <td>@a.TipoAlerta</td>
                            <td><span class="badge badge-estado-@a.Estado">@a.Estado</span></td>
                            <td>@(a.Leida ? "Sí" : "No")</td>
                            <td>@a.Mensaje</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">Eventos SOS (@Model.EventosSos.Count)</div>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Fecha</th>
                            <th>Estado</th>
                            <th>Atendido</th>
                            <th>Mensaje</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var e in Model.EventosSos)
                    {
                        <tr>
                            <td class="text-nowrap">@e.FechaHora.ToString("g")</td>
                            <td><span class="badge badge-estado-@e.Estado">@e.Estado</span></td>
                            <td>@(e.Atendido ? "Sí" : "No")</td>
                            <td>@e.Mensaje</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.pulseraRealtimeReload = () => window.location.reload();
    </script>
}
